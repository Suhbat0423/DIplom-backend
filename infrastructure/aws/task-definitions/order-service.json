{
  "family": "order-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "__ECS_EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__ECS_TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "order-service",
      "image": "__AWS_ACCOUNT_ID__.dkr.ecr.__AWS_REGION__.amazonaws.com/ecom/order-service:__IMAGE_TAG__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3005,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "HOST", "value": "0.0.0.0" },
        { "name": "PORT", "value": "3005" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "MONGODB_URI", "value": "__MONGODB_URI__" },
        { "name": "CART_SERVICE_URL", "value": "__CART_SERVICE_URL__" },
        { "name": "INTERNAL_API_KEY", "value": "__INTERNAL_API_KEY__" },
        { "name": "JWT_SECRET", "value": "__JWT_SECRET__" },
        { "name": "CLEAR_CART_AFTER_ORDER", "value": "true" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ecom/order-service",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
