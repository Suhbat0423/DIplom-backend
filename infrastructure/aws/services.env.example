AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=123456789012
ECS_CLUSTER_NAME=ecom-backend-cluster
ECS_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/ecsTaskExecutionRole
ECS_TASK_ROLE_ARN=arn:aws:iam::123456789012:role/ecomBackendTaskRole
IMAGE_TAG=latest

MONGODB_URI=mongodb://username:password@your-mongodb-host:27017/ecom
JWT_SECRET=replace-with-a-real-secret
INTERNAL_API_KEY=replace-with-a-real-internal-key

API_GATEWAY_DESIRED_COUNT=1
USER_SERVICE_DESIRED_COUNT=1
PRODUCT_SERVICE_DESIRED_COUNT=1
STORE_SERVICE_DESIRED_COUNT=1
CART_SERVICE_DESIRED_COUNT=1
ORDER_SERVICE_DESIRED_COUNT=1
PAYMENT_SERVICE_DESIRED_COUNT=1

API_GATEWAY_MIN_CAPACITY=1
API_GATEWAY_MAX_CAPACITY=4
PRODUCT_SERVICE_MIN_CAPACITY=1
PRODUCT_SERVICE_MAX_CAPACITY=4
CART_SERVICE_MIN_CAPACITY=1
CART_SERVICE_MAX_CAPACITY=4
ORDER_SERVICE_MIN_CAPACITY=1
ORDER_SERVICE_MAX_CAPACITY=4
PAYMENT_SERVICE_MIN_CAPACITY=1
PAYMENT_SERVICE_MAX_CAPACITY=4

API_GATEWAY_TARGET_CPU=60
PRODUCT_SERVICE_TARGET_CPU=60
CART_SERVICE_TARGET_CPU=60
ORDER_SERVICE_TARGET_CPU=60
PAYMENT_SERVICE_TARGET_CPU=60

# Internal ECS service URLs used by api-gateway and inter-service calls.
USER_SERVICE_URL=http://user-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
STORE_SERVICE_URL=http://store-service:3003
CART_SERVICE_URL=http://cart-service:3004
ORDER_SERVICE_URL=http://order-service:3005
PAYMENT_SERVICE_URL=http://payment-service:3006

# Service discovery or naming assumptions for ECS services.
API_GATEWAY_SERVICE_NAME=api-gateway
USER_SERVICE_NAME=user-service
PRODUCT_SERVICE_NAME=product-service
STORE_SERVICE_NAME=store-service
CART_SERVICE_NAME=cart-service
ORDER_SERVICE_NAME=order-service
PAYMENT_SERVICE_NAME=payment-service
